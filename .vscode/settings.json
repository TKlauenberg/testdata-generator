{
  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 50,
  "github.copilot.chat.agent.runTasks": true,
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "github.copilot.chat.agent.autoFix": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "typescript"
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "cucumber.glue": [
    "**/features/**/*.ts"
  ],
  "chat.tools.terminal.autoApprove": {
    "/^bun run format$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cd packages/cli && bun run build$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bun bin/td\\.ts validate .*$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cd /run/media/tobi/Data/testdata/testdata-ai && bun run build$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bun run build(( 2>&1 \\| tail -[0-9]+)|())$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^git rev-parse --is-inside-work-tree && git status --porcelain && echo '---UNSTAGED---' && git diff --name-only && echo '---STAGED---' && git diff --cached --name-only$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bun run --cwd packages/core build$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^bun run --cwd packages/core test:bdd$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}