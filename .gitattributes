# Ensure consistent line endings across platforms
* text=auto

# Feature files must use LF (required for Cucumber/Gherkin parsing)
*.feature text eol=lf

# TypeScript/JavaScript files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# Markdown files
*.md text eol=lf

# YAML files
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
