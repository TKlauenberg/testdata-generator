{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@testdata-generator/core": [
        "./packages/core/src/index.ts"
      ]
    },
    "baseUrl": "."
  },
  "exclude": [
    "node_modules",
    "dist"
  ]
}