{
  "name": "testdata-generator",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/core build && bun run --cwd packages/cli build",
    "test": "bun test packages/",
    "test:core": "bun test packages/core",
    "test:cli": "bun test packages/cli",
    "test:bdd": "bun run --cwd packages/core test:bdd && bun run --cwd packages/cli test:bdd",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:file-naming": "bun scripts/validate-file-naming.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/bun": "^1.3.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}